{
  "name": "@mymosdk/avatar",
  "version": "0.1.8",
  "description": "Lightweight animated avatar SDK for any web application",
  "keywords": [
    "avatar",
    "animation",
    "3d",
    "sdk",
    "webgl",
    "three.js"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/mymo-avatar.cjs",
  "module": "./dist/mymo-avatar.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mymo-avatar.js",
      "require": "./dist/mymo-avatar.cjs",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs",
      "types": "./dist/vue/index.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte.js",
      "require": "./dist/svelte.cjs",
      "types": "./dist/svelte/index.d.ts"
    },
    "./angular": {
      "import": "./dist/angular.js",
      "require": "./dist/angular.cjs",
      "types": "./dist/angular/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JairoGerardo/mymo-avatar.git"
  },
  "homepage": "https://mymosdk.meshicode.com",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.umd.config.ts && tsc -p tsconfig.json --emitDeclarationOnly",
    "prepack": "node -e \"require('fs').copyFileSync('../../README.md', 'README.md')\"",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "docs": "typedoc --options typedoc.json"
  },
  "peerDependencies": {
    "three": ">=0.165.0",
    "react": ">=18.0.0",
    "vue": ">=3.0.0",
    "svelte": ">=4.0.0",
    "@angular/core": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/three": "^0.165.0",
    "jsdom": "^29.1.1",
    "react": "^18.0.0",
    "three": "^0.165.0",
    "typedoc": "^0.28.19",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.4"
  }
}

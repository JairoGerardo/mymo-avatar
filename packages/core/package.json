{
  "name": "@mymo/avatar",
  "version": "0.1.0",
  "description": "Lightweight animated avatar SDK for any web application",
  "keywords": [
    "avatar",
    "animation",
    "3d",
    "sdk",
    "webgl",
    "three.js"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/mymo-avatar.cjs",
  "module": "./dist/mymo-avatar.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mymo-avatar.js",
      "require": "./dist/mymo-avatar.cjs",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs",
      "types": "./dist/vue/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.umd.config.ts && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "docs": "typedoc --options typedoc.json"
  },
  "peerDependencies": {
    "three": ">=0.165.0",
    "react": ">=18.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/three": "^0.165.0",
    "jsdom": "^29.1.1",
    "react": "^18.0.0",
    "three": "^0.165.0",
    "typedoc": "^0.28.19",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.4"
  }
}

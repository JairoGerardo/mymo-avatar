{
  "name": "@mymo/react",
  "version": "0.1.0",
  "description": "React wrapper for @mymo/avatar",
  "keywords": ["mymo", "avatar", "react"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@mymo/avatar": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@mymo/avatar": "workspace:*",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  }
}

{
  "name": "@mymo/plugin-elevenlabs",
  "version": "0.1.0",
  "description": "ElevenLabs TTS plugin for @mymo/avatar",
  "keywords": ["mymo", "avatar", "elevenlabs", "tts", "plugin"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@mymo/avatar": "workspace:*"
  },
  "devDependencies": {
    "@mymo/avatar": "workspace:*",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  }
}

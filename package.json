{
  "name": "mymo-avatar-monorepo",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "description": "Mymo Avatar — monorepo root",
  "scripts": {
    "build": "pnpm --filter @mymosdk/avatar build",
    "build:all": "pnpm --filter @mymosdk/avatar build && pnpm --filter \"!@mymosdk/avatar\" --filter \"!@mymo/example-*\" -r build",
    "docs": "pnpm --filter @mymosdk/avatar docs",
    "dev": "pnpm --filter @mymosdk/avatar dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "~5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
